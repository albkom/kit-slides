# .env.example — copy to .env and set ONE of these configurations

# Option A: CSV files (default — no config needed)
VITE_DATA_SOURCE=csv
VITE_CSV_PATH=./data

# Option B: Local C# host (SQLite)
# VITE_DATA_SOURCE=local
# VITE_LOCAL_PORT=5000

# Option C: Hosted web API
# VITE_DATA_SOURCE=rest
# VITE_API_BASE=https://your-api.azurewebsites.net
