# Sorgente dati: "csv" | "rest" | "local"
VITE_DATA_SOURCE=csv

# Path della cartella contenente i CSV.
# Può essere assoluto (es. C:\dati\report) oppure relativo alla cartella public/ del deck.
VITE_CSV_PATH=./data

# Endpoint base per l'adapter REST (se VITE_DATA_SOURCE=rest)
# VITE_API_BASE=http://localhost:3000

# Porta per l'adapter locale C# (se VITE_DATA_SOURCE=local)
# VITE_LOCAL_PORT=5000
